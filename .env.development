# 开发环境变量配置
# 本文件仅在本地开发时使用，已被 .gitignore 排除，不会进入版本控制
#
# 使用方法：
#   1. 直接填入你的配置值
#   2. 运行示例前加载：export $(cat .env.development | xargs)
#   或程序中自动读取（如使用 python-dotenv）

# DeepSeek API
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# 可选：其他模型配置
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
